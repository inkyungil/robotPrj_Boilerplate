# 로봇 PC마다 이 한 줄만 다릅니다.
# arm     → JetCobot (pymycobot)
# driving → Pinky    (ROS2 navigation)
ROBOT_TYPE=arm

# FastAPI 서버 포트 (중앙 서버가 :9001 로 접속)
PORT=9001
HOST=0.0.0.0

# (driving 전용) rclpy 노드 이름
ROS_NODE_NAME=robot_agent

# 카메라 색상 반전/왜곡 보정 설정 (none / rgb_bgr / yuv_uv)
# - none: 기본값
# - rgb_bgr: Red와 Blue 채널이 서로 바뀌어 나올 때 설정
# - yuv_uv: Blue가 Yellow 등으로 색상이 왜곡되어 나올 때 설정 (U/V 채널 스왑)
CAMERA_COLOR_SWAP=none
