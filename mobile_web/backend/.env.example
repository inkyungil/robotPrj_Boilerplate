# Copy to .env and fill in real values. .env is git-ignored.

# SQLAlchemy DB URL for the labi MariaDB.
# Format: mysql+pymysql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=mysql+pymysql://labi_user:CHANGE_ME@localhost:3306/labi

# JWT signing — generate a long random value, e.g.:
#   python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Comma-separated allowed CORS origins (the frontend dev server).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Initial superadmin created by scripts/seed_admin.py.
# Leave SEED_ADMIN_PASSWORD blank to auto-generate one (printed once).
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=
